# JARVIS OS - Environment Variables Template
# Copy this file to .env and fill in active keys

# System Profile settings (development / staging / production)
JARVIS_SYSTEM_ENVIRONMENT=development
JARVIS_SYSTEM_DEBUG=true
JARVIS_SYSTEM_LOG_LEVEL=DEBUG

# Database Configuration
JARVIS_DATABASE_HOST=localhost
JARVIS_DATABASE_PORT=5432
JARVIS_DATABASE_NAME=jarvis_db
JARVIS_DATABASE_USERNAME=jarvis_user
JARVIS_DATABASE_PASSWORD=secret_password_here

# Redis Stream Broker
JARVIS_REDIS_HOST=localhost
JARVIS_REDIS_PORT=6379
JARVIS_REDIS_PASSWORD=

# Encryption master key path
JARVIS_VAULT_ENCRYPTION_KEY_PATH=secrets/master.key
