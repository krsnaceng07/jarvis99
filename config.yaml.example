# JARVIS OS - Configuration Settings Profile Template
# Copy this file to config.yaml and customize settings

system:
  environment: "development"  # development / staging / production
  debug: true
  log_level: "DEBUG"

database:
  host: "localhost"
  port: 5432
  name: "jarvis_db"
  username: "jarvis_user"

redis:
  host: "localhost"
  port: 6379

vault:
  encryption_key_path: "secrets/master.key"
