# JARVIS OS - Configuration Settings Profile Template
# Copy this file to config.yaml and customize settings

system:
  environment: "development"  # development / staging / production
  debug: true
  log_level: "DEBUG"

database:
  host: "localhost"
  port: 5432
  name: "jarvis_db"
  username: "jarvis_user"

redis:
  host: "localhost"
  port: 6379

vault:
  encryption_key_path: "secrets/master.key"

memory:
  disable_auto_memory: false
  retrieval:
    tier1_limit: 20
    tier2_limit: 20
    tier3_limit: 30
    tier4_limit: 10
    semantic_top_k: 15
