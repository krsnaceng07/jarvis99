# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Pyinstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Translation files
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Sphinx documentation
doc/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#1255, pipenv should generally not be tracked
#   but may be shared if desired.
# Pipfile.lock

# poetry
#   Similar to Pipenv, Pyproject.toml should be checked in, but poetry.lock is optional
# poetry.lock

# pdm
#   Similar to Pipenv, pyproject.toml should be checked in, but pdm.lock is optional
# pdm.lock

# PEP 582; used by e.g. github.com/lincolnloop/layman and pdm
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# pytype static type checker
.pytype/

# Cython debug symbols
cython_debug/

# OS metadata
.DS_Store
Thumbs.db

# Project local configs and vaults
config.yaml
secrets/
.vault_key
*.key

# Test artifacts (mission DBs created by test runs)
test_missions_*.db
test_missions_*.db-shm
test_missions_*.db-wal

# Local analysis/visualization artifacts
JARVIS_CODEBASE_ANALYSIS.html

# Old venv accidentally committed
.venv-py310/

# Audit outputs — keep .md reports tracked, ignore ephemeral data
.audit/*.log
.audit/*.csv
.audit/*.json
.audit/*.py

# Root-level transient validation artifacts — regenerated on every run.
# These get clobbered by the test harness and contain MagicMock reprs
# when the run fails partway; treat as ephemeral.
audit_report.json
jarvis_dev.db
jarvis_dev.db-journal
jarvis_dev.db-shm
jarvis_dev.db-wal

# Ad-hoc DB / config backups (timestamped dumps from scripts/runtime_sweep.py)
backups/

# Capability matrix outputs — regenerated by scripts/capability_matrix.py
# on every run. Not source-of-truth; treat as derived artifacts.
JARVIS_CAPABILITY_MATRIX.md
JARVIS_CAPABILITY_MATRIX.json

# Ad-hoc debug helpers — one-off scripts with hardcoded local paths
# (Windows-only, e.g. r"E:\jarvis\..."). Not part of the codebase;
# regenerate on demand. Named with leading dots to keep them hidden.
.inspect_*.py
.run_with_env.py

# Server startup error log — captured from background uvicorn launches
# during ad-hoc validation. Not a log we want in the repo.
startup.err
